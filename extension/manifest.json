{
  "manifest_version": 3,
  "name": "Clean Reader",
  "version": "1.1",
  "description": "Clean Reader by ccgauche | Clean reader make for a clean, simpler, greener web.",
  "icons": {
    "88": "icons.png"
  },
  "permissions": ["contextMenus", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["cr.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
